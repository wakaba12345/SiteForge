{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "ANTHROPIC_API_KEY",
        "REVALIDATION_SECRET",
        "NEXT_PUBLIC_DASHBOARD_URL",
        "VERCEL_TOKEN",
        "VERCEL_TEAM_ID",
        "REVALIDATION_TARGET_URL",
        "SITE_SLUG",
        "ADMIN_PASSWORD",
        "ADMIN_HMAC_SECRET"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
